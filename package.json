{
  "name": "@upstart.gg/lucerna",
  "version": "0.1.17",
  "description": "AST-aware semantic + lexical code indexer for AI agents",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "lucerna": "./dist/cli.mjs",
    "lucerna-mcp": "./dist/mcp.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "ci:test": "bun test --coverage --coverage-reporter=lcov",
    "test:dist": "bun test src/tests/cli.dist.test.ts",
    "test:integration": "cross-env INTEGRATION_TESTS=1 bun test --timeout 60000 src/tests/integration.test.ts src/tests/*.integration.test.ts src/tests/CloudflareEmbeddings.test.ts src/tests/CloudflareReranker.test.ts src/tests/JinaReranker.test.ts src/tests/VoyageReranker.test.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check --write",
    "ci:lint": "biome ci .",
    "dev": "bun run src/cli/index.ts",
    "bench": "bun scripts/benchmark.ts",
    "bench:no-semantic": "BENCH_SEMANTIC=0 bun scripts/benchmark.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@kreuzberg/tree-sitter-language-pack": "^1.6.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@changesets/changelog-github": "^0.6.0 ",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "cross-env": "^10.1.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/upstart-gg/lucerna"
  },
  "keywords": [
    "lucerna",
    "semantic-search",
    "code-search",
    "ai-agent",
    "rag",
    "tree-sitter",
    "lancedb"
  ],
  "license": "MIT"
}
